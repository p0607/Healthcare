# ── Development (Vite dev server proxies /api → backend) ──
VITE_PROXY_API=http://localhost:5050

# ── Production Docker / static build ──
# Leave as /api when nginx proxies to the API container (see frontend/nginx.conf)
# VITE_API_URL=/api

# Optional: direct Socket.IO URL if not same-origin (usually omit in Docker — nginx proxies /socket.io)
# VITE_SOCKET_URL=https://your-domain.com

# Healthcare fall-detection (optional separate service)
# VITE_HEALTHCARE_API_BASE=http://localhost:4000/api
# VITE_HEALTHCARE_ALERTS_ENABLED=false
