# Local Docker Compose — copy to .env at repo root:
#   copy .env.local.example .env
# Or auto-generate from backend/.env:
#   powershell -ExecutionPolicy Bypass -File scripts/setup-local-env.ps1
#
# Never commit .env with real passwords.

# ── Local Postgres on your PC (Docker reaches host via host.docker.internal) ──
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_URL_ENCODED@host.docker.internal:5432/nurse_care

# ── API (used by api container) ──
JWT_SECRET=dev-change-me-use-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Web + Socket CORS — Docker web on port 8080; add Vite dev port if you also run npm run dev
CLIENT_ORIGIN=http://localhost:8080,http://localhost:5173

# Optional: seed demo users on first container start (one-time)
# SEED_ON_START=1

# ── Replace when you deploy to Azure / your web server ──
# DATABASE_URL=postgresql://user@server:pass@server.postgres.database.azure.com:5432/nurse_care?sslmode=require
# CLIENT_ORIGIN=https://your-domain.com
