# Copy to .env and edit, OR run:
#   powershell -ExecutionPolicy Bypass -File scripts/setup-env.ps1 -Mode emulator
#   powershell -ExecutionPolicy Bypass -File scripts/setup-env.ps1 -Mode phone
#   powershell -ExecutionPolicy Bypass -File scripts/setup-env.ps1 -Mode staging -ApiHost https://your-domain.com
#
# EXPO_PUBLIC_* is baked at build time for EAS; for `expo start` it reloads from .env.

# ── Android emulator (API running on PC with npm run dev or Docker :5050) ──
EXPO_PUBLIC_API_URL=http://10.0.2.2:5050/api
EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:5050

# ── Physical phone (same Wi‑Fi as PC — replace with your PC LAN IP) ──
# EXPO_PUBLIC_API_URL=http://192.168.50.240:5050/api
# EXPO_PUBLIC_SOCKET_URL=http://192.168.50.240:5050

# ── Staging / production (HTTPS required for store builds) ──
# EXPO_PUBLIC_API_URL=https://your-domain.com/api
# EXPO_PUBLIC_SOCKET_URL=https://your-domain.com
#
# EAS push (SOS in background) — set after `eas init`:
# EAS_PROJECT_ID=your-eas-project-uuid
