{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:5050/api",
        "EXPO_PUBLIC_SOCKET_URL": "http://10.0.2.2:5050"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://YOUR-DOMAIN.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://YOUR-DOMAIN.com"
      }
    },
    "staging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://YOUR-STAGING-DOMAIN.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://YOUR-STAGING-DOMAIN.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_URL": "https://YOUR-DOMAIN.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://YOUR-DOMAIN.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "your-apple-id@company.com",
        "ascAppId": "0000000000",
        "appleTeamId": "XXXXXXXXXX"
      }
    }
  }
}
