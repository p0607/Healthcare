{
  "cli": {
    "version": ">= 20.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://q9lab.in/healthcare/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://q9lab.in"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://q9lab.in/healthcare/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://q9lab.in"
      }
    },
    "staging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://q9lab.in/healthcare/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://q9lab.in"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_URL": "https://q9lab.in/healthcare/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://q9lab.in"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
