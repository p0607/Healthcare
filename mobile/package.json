{
  "name": "nurse-care-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --port 8010 --clear",
    "start:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/start-emulator.ps1",
    "start:phone": "powershell -ExecutionPolicy Bypass -File ./scripts/start-phone.ps1",
    "android": "powershell -ExecutionPolicy Bypass -File ./scripts/start-emulator.ps1",
    "android:phone": "powershell -ExecutionPolicy Bypass -File ./scripts/start-phone.ps1",
    "mobile:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/start-emulator.ps1",
    "open:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/open-expo.ps1",
    "check:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/check-emulator.ps1",
    "kill:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-ports.ps1",
    "ios": "expo start --port 8010 --ios --clear",
    "web": "expo start --port 8010 --web",
    "tunnel": "powershell -ExecutionPolicy Bypass -File ./scripts/tunnel.ps1",
    "env:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-env.ps1 -Mode emulator",
    "env:phone": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-env.ps1 -Mode phone",
    "open-firewall": "powershell -ExecutionPolicy Bypass -File ./scripts/open-firewall.ps1",
    "fix-deps": "expo install --fix",
    "eas:login": "eas login",
    "eas:init": "eas init",
    "build:android:production": "eas build --platform android --profile production",
    "build:android:preview": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@nursecare/shared": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.18.0",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.0",
    "expo-device": "~8.0.10",
    "expo-linking": "~8.0.0",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~3.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-razorpay": "^2.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "eas-cli": "^20.5.0"
  }
}
