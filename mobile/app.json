{
  "expo": {
    "name": "Care360",
    "slug": "healthcare",
    "scheme": "nursecare",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/brand-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2f1f6"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nursecare.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nursecare.app",
      "usesCleartextTraffic": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f2f1f6"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#f43f5e"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Care360 to use your location for home visit addresses."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "506abcc3-57e0-4aa2-95fe-8de5364b9449"
      }
    },
    "owner": "alchemy-techsol"
  }
}
