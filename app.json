{
  "expo": {
    "name": "Nurse Care",
    "slug": "healthcare",
    "scheme": "nursecare",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a9bf0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nursecare.app"
    },
    "android": {
      "package": "com.nursecare.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a9bf0"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Nurse Care to use your location for home visit addresses."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "506abcc3-57e0-4aa2-95fe-8de5364b9449"
      }
    },
    "owner": "alchemy-techsol"
  }
}
