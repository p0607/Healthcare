PORT=5050
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nurse_care
JWT_SECRET=replace_with_strong_secret_min_32_chars
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:8080,http://localhost:5173

# Production only — forgot-password email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=911 Nurse Care <your.email@gmail.com>

# Optional — Razorpay (free to register at dashboard.razorpay.com)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# VISIT_OTP_TTL_MS=300000
# PASSWORD_RESET_OTP_TTL_MS=600000
