# Production / deployment environment variables

PORT=5050

# PostgreSQL — Azure Database for PostgreSQL Flexible Server
# Username format on Azure: myuser@myserver
# DATABASE_URL=postgresql://myuser@myserver:PASSWORD@myserver.postgres.database.azure.com:5432/nurse_care?sslmode=require

# Local Docker Postgres (optional dev only):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nurse_care

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nurse_care

JWT_SECRET=replace_this_with_a_strong_secret_min_32_chars_in_production
JWT_EXPIRES_IN=7d

# Bootstrap super admin on seed (defaults to admin@alchemy.com)
# SUPER_ADMIN_EMAIL=you@company.com

# Comma-separated allowed browser origins (web app URL in production — HTTPS only in prod)
# Docker local test: http://localhost:8080
CLIENT_ORIGIN=http://localhost:8080,http://localhost:5173

# Visit OTP (optional)
# VISIT_OTP_TTL_MS=300000
# VISIT_OTP_MAX_ATTEMPTS=5

# Database migrations (production Docker uses migrate deploy by default):
#   npm run db:migrate:deploy
# If the DB was created earlier with db push, baseline once:
#   npm run db:migrate:baseline

# Password reset email OTP — required in production (NODE_ENV=production)
# Without these, dev mode shows the code in the app + backend terminal only.
#
# Gmail example (use a Google App Password, not your normal password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=911 Nurse Care <your.email@gmail.com>
#
# PASSWORD_RESET_OTP_TTL_MS=600000
# PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
