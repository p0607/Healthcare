# Copy to .env before: docker compose up --build

# Never commit .env with real secrets.



# ── Azure Database for PostgreSQL (Flexible Server) ──

# Format: postgresql://USER@SERVERNAME:PASSWORD@SERVERNAME.postgres.database.azure.com:5432/DATABASE?sslmode=require

# Encode special chars in password (@=%40 #=%23 etc.)

DATABASE_URL=postgresql://nursecare_admin@your-server:CHANGE_ME@your-server.postgres.database.azure.com:5432/nurse_care?sslmode=require



# ── API auth ──

# Generate: node backend/scripts/generate-jwt-secret.js

JWT_SECRET=generate-a-long-random-string-min-32-chars

JWT_EXPIRES_IN=7d



# ── CORS + Socket.IO allowed origins (comma-separated HTTPS web URLs) ──

# Mobile native apps do not use CORS for API calls.

CLIENT_ORIGIN=https://your-domain.com,https://www.your-domain.com



# ── Email (required in production for forgot-password OTP) ──

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_USER=your.email@gmail.com

SMTP_PASS=your-google-app-password

SMTP_FROM=911 Nurse Care <your.email@gmail.com>



# ── Bootstrap super admin on seed (optional) ──

# SUPER_ADMIN_EMAIL=ops@your-company.com



# ── Docker startup ──

# Use migrate deploy (default). Set PRISMA_DB_PUSH=1 only for local dev containers.

# PRISMA_DB_PUSH=0

# SEED_ON_START=0

#

# If the Azure DB was created earlier with prisma db push, baseline once before deploy:

#   cd backend && npm run db:migrate:baseline



# ── Visit / password OTP (optional) ──

# VISIT_OTP_TTL_MS=300000

# VISIT_OTP_MAX_ATTEMPTS=5

# PASSWORD_RESET_OTP_TTL_MS=600000

# PASSWORD_RESET_OTP_MAX_ATTEMPTS=5

