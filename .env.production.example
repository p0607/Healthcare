# Copy to .env at repo root: docker compose up --build

# Local Postgres container (service "db" in docker-compose.yml, not published to the host).
# POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB configure the db container itself; DATABASE_URL
# must reference the same values via the "db" service name (containers resolve each other by name).
POSTGRES_USER=nursecare
POSTGRES_PASSWORD=
POSTGRES_DB=nurse_care
DATABASE_URL=postgresql://nursecare:PASSWORD@db:5432/nurse_care?schema=public

JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=https://your-domain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=911 Nurse Care <noreply@your-domain.com>

RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=

# Optional: cd backend && npm run db:migrate:baseline  (if DB was created with db push)
# SEED_ON_START=0
# PRISMA_DB_PUSH=0
