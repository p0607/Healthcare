# Copy to .env at repo root: docker compose up --build

DATABASE_URL=postgresql://user@server:PASSWORD@server.postgres.database.azure.com:5432/nurse_care?sslmode=require
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=https://your-domain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=911 Nurse Care <noreply@your-domain.com>

RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=

# Optional: cd backend && npm run db:migrate:baseline  (if DB was created with db push)
# SEED_ON_START=0
# PRISMA_DB_PUSH=0
